{
  "scale": {
    "min": 1,
    "max": 10,
    "display": "/10"
  },
  "verdicts": {
    "high_confidence": {
      "min": 8.0,
      "label": "HIGH CONFIDENCE",
      "action": "Proceed with confidence"
    },
    "moderate_confidence": {
      "min": 6.0,
      "label": "MODERATE CONFIDENCE",
      "action": "Proceed with awareness of gaps"
    },
    "low_confidence": {
      "min": 4.0,
      "label": "LOW CONFIDENCE",
      "action": "Investigate further before proceeding"
    },
    "no_consensus": {
      "min": 1.0,
      "label": "NO CONSENSUS",
      "action": "Do not proceed — revisit analysis"
    }
  },
  "validators": {
    "deep_verifier": {
      "role": "Claim verification against evidence",
      "model": "opus",
      "fallback": "sonnet"
    },
    "devils_advocate": {
      "role": "Counter-argument and bias detection",
      "model": "codex",
      "fallback": "sonnet"
    },
    "scope_analyst": {
      "role": "Second-order effects and missing perspectives",
      "model": "gemini",
      "fallback": "sonnet"
    }
  },
  "consensus_formula": "average of all validator confidence scores",
  "disagreement_threshold": 3.0,
  "disagreement_note": "Flag when any two validators differ by more than 3 points"
}
